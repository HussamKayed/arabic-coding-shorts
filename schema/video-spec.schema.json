{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSpec",
  "description": "Contract between all pipeline modules. Produced by the Script Agent, consumed by TTS, the Remotion renderer, FFmpeg assembly, and the uploader.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "topic_id", "language", "video", "voice", "metadata", "scenes"],
  "properties": {
    "spec_version": { "const": "1.0" },
    "topic_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
    "language": { "const": "ar" },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "width", "height", "fps", "target_duration_s"],
      "properties": {
        "format": { "const": "short" },
        "width": { "const": 1080 },
        "height": { "const": 1920 },
        "fps": { "const": 30 },
        "target_duration_s": { "type": "number", "minimum": 45, "maximum": 100 }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voice_id", "rate", "pitch"],
      "properties": {
        "voice_id": {
          "enum": [
            "ar-EG-ShakirNeural",
            "ar-EG-SalmaNeural",
            "ar-SA-HamedNeural",
            "ar-SA-ZariyahNeural"
          ]
        },
        "rate": { "type": "string", "pattern": "^[+-]\\d{1,3}%$" },
        "pitch": { "type": "string", "pattern": "^[+-]\\d{1,3}Hz$" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "tags", "category_id", "ai_disclosure", "privacy_status", "default_language"],
      "properties": {
        "title": { "type": "string", "minLength": 10, "maxLength": 100 },
        "description": { "type": "string", "minLength": 50, "maxLength": 4500 },
        "tags": {
          "type": "array",
          "minItems": 3,
          "maxItems": 15,
          "items": { "type": "string", "minLength": 2, "maxLength": 40 }
        },
        "category_id": { "enum": ["27", "28"] },
        "ai_disclosure": { "const": true },
        "privacy_status": { "const": "private" },
        "default_language": { "const": "ar" }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "vo_text", "target_duration_s", "transition_out"],
      "properties": {
        "id": { "type": "string", "pattern": "^s[0-9]{1,2}$" },
        "type": { "enum": ["hook", "code", "diagram", "payoff"] },
        "vo_text": { "type": "string", "minLength": 5, "maxLength": 600 },
        "on_screen_text": { "type": "string", "minLength": 3, "maxLength": 90 },
        "code": { "$ref": "#/$defs/code_block" },
        "diagram": { "$ref": "#/$defs/diagram" },
        "target_duration_s": { "type": "number", "minimum": 2, "maximum": 30 },
        "transition_out": { "enum": ["cut", "fade", "slide"] }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "code" } } },
          "then": { "required": ["code"] }
        },
        {
          "if": { "properties": { "type": { "const": "diagram" } } },
          "then": { "required": ["diagram"] }
        },
        {
          "if": { "properties": { "type": { "const": "hook" } } },
          "then": { "required": ["on_screen_text"] }
        }
      ]
    },
    "code_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "content"],
      "properties": {
        "language": { "enum": ["javascript", "typescript", "json", "bash", "sql", "http"] },
        "content": { "type": "string", "minLength": 10, "maxLength": 700 },
        "highlights": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_line", "end_line"],
            "properties": {
              "start_line": { "type": "integer", "minimum": 1 },
              "end_line": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string", "minLength": 1, "maxLength": 20 },
              "label": { "type": "string", "minLength": 1, "maxLength": 30 }
            }
          }
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": "string", "maxLength": 25 }
            }
          }
        }
      }
    }
  }
}
